# RADICAL SEA BUNNY - Environment Configuration

# Application
RADICAL_SEA_BUNNY_ENV=production
VERSION=2.0.0
DEBUG=False
SECRET_KEY=your-secret-key-here

# Web Dashboard
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_REQUIRE_AUTH=False
WEB_USERNAME=admin
WEB_PASSWORD=radical_sea_bunny_2024

# Database
DB_PATH=.radical_sea_bunny/radical_sea_bunny.db

# Platform Integrations
# Discord
DISCORD_ENABLED=False
DISCORD_TOKEN=
DISCORD_PREFIX=!

# Slack
SLACK_ENABLED=False
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_PREFIX=!

# Telegram
TELEGRAM_ENABLED=False
TELEGRAM_BOT_TOKEN=
TELEGRAM_PREFIX=/

# Signal
SIGNAL_ENABLED=False
SIGNAL_PHONE_NUMBER=
SIGNAL_PREFIX=!

# iMessage (macOS only)
IMESSAGE_ENABLED=False
IMESSAGE_PREFIX=!

# Google Chat
GOOGLE_CHAT_ENABLED=False
GOOGLE_CHAT_WEBHOOK_URL=
GOOGLE_CHAT_PREFIX=/

# Security Settings
AUTO_BLOCK_ENABLED=False
AUTO_BLOCK_THRESHOLD=5
SCAN_TIMEOUT=30

# Traffic Generation
TRAFFIC_ENABLED=True
TRAFFIC_MAX_DURATION=300
TRAFFIC_MAX_PACKET_RATE=1000
TRAFFIC_ALLOW_FLOODS=False

# Social Engineering
SOCIAL_ENGINEERING_ENABLED=True
PHISHING_DEFAULT_PORT=8080
CAPTURE_CREDENTIALS=True
AUTO_SHORTEN_URLS=True

# SSH
SSH_ENABLED=True
SSH_DEFAULT_TIMEOUT=30
SSH_MAX_CONNECTIONS=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=.radical_sea_bunny/radical_sea_bunny.log

# Reporting
REPORT_FORMAT=html
GENERATE_GRAPHICS=True
REPORT_DIR=radical_sea_bunny_reports